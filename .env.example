# Backend API target URL
# Supports: llama.cpp server, vLLM, or any OpenAI-compatible API
# Examples:
#   llama.cpp:  http://localhost:8080
#   vLLM:       http://localhost:8000
#   Remote:     http://192.168.17.59:11434
VITE_API_TARGET=http://localhost:8080

# Application name (displayed in page title and UI)
VITE_PUBLIC_APP_NAME=LiteChat

# API Key (optional, for servers requiring authentication)
# VITE_API_KEY=your-api-key-here
